config ABK_EBPF_ROOT
	bool "ABK eBPF root PoC"
	depends on BPF && BPF_SYSCALL
	select BPF_LSM
	help
	  Experimental helper for an eBPF-assisted root PoC on Android GKI.
	  This keeps the privileged primitive in a small in-tree module while
	  policy and auditing can live in eBPF programs loaded by a trusted
	  daemon.
